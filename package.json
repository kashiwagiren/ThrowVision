{
  "name": "throwvision",
  "version": "1.0.0",
  "description": "Real-Time, Vision-Based Automated Scoring System for Steel-Tip Darts",
  "main": "electron/main.js",
  "scripts": {
    "start": "node -e \"const {execFileSync}=require('child_process');execFileSync(require('electron'),['.'],{stdio:'inherit',cwd:process.cwd()})\"",
    "start:dev": "node -e \"const {execFileSync}=require('child_process');execFileSync(require('electron'),['.',  '--dev'],{stdio:'inherit',cwd:process.cwd()})\"",
    "build": "node node_modules/electron-builder/cli.js",
    "build:win": "node node_modules/electron-builder/cli.js --win",
    "build:linux": "node node_modules/electron-builder/cli.js --linux",
    "pyinstaller": ".venv\\Scripts\\pyinstaller throwvision.spec --clean --noconfirm"
  },
  "build": {
    "appId": "com.kashiwagiren.throwvision",
    "productName": "ThrowVision",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "dir"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }

  },
  "keywords": [
    "darts",
    "computer-vision",
    "scoring",
    "electron"
  ],
  "author": "kashiwagiren",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "typescript": "^5.9.3"
  }
}
